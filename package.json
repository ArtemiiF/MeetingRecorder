{
  "name": "meeting-recorder",
  "version": "1.4.7",
  "description": "Локальная запись встреч: микрофон + системный звук → транскрипт → сводка по промпту",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/mainutil.test.js tests/renderer.test.js && ../venv/bin/python -m pytest tests/ -q",
    "test:js": "node --test tests/mainutil.test.js tests/renderer.test.js",
    "test:py": "../venv/bin/python -m pytest tests/ -q",
    "test:e2e": "node --test e2e/boot.test.js",
    "dist:mac": "electron-builder --mac --arm64"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "26.15.3",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1"
  },
  "dependencies": {
    "audiotee": "^0.0.7"
  },
  "build": {
    "appId": "com.artemii.meetingrecorder",
    "productName": "Meeting Recorder",
    "files": [
      "main.js",
      "preload.js",
      "presets.example.json",
      "events.json",
      "lib/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend.py",
        "to": "backend.py"
      },
      {
        "from": "events.json",
        "to": "events.json"
      },
      {
        "from": "requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "vendor/wheels",
        "to": "vendor/wheels"
      }
    ],
    "asarUnpack": [
      "node_modules/audiotee/bin/**",
      "assets/trayTemplate*.png"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "identity": "-",
      "hardenedRuntime": true,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Приложению нужен доступ к микрофону для записи встреч.",
        "NSAudioCaptureUsageDescription": "Приложению нужен доступ к записи системного звука для захвата голосов собеседников."
      }
    }
  }
}
